@model IEnumerable<Book_store.Models.Book>

@{
    ViewData["Title"] = "Index";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}
<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <img src="@item.ImageUrl"
                     class="card-img-top"
                     alt="@item.Title"
                     style="height: 300px; object-fit: cover;" />
                <div class="card-body">
                    <h4>@item.Title</h4>
                    <p>Price: @item.Price.ToString("C")</p>
                    <p>Publisher: @item.Publisher?.Name</p>
                    <a asp-action="Details"
                       asp-route-id="@item.Id" class="btn btn-primary">Details</a>
                    <a asp-action="AddToReadingList"
                       asp-route-id="@item.Id" class="btn btn-primary">
                        Add To Reading List
                    </a>
                </div>
            </div>
        </div>
    }
</div>